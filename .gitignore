# --- DEPENDENCIES ---
# Never upload the heavy library folders
node_modules/
.pnpm-store/

# --- BUILD OUTPUT ---
# Production files generated during build
dist/
dist-ssr/
build/
temp/
*.tsbuildinfo

# --- ENVIRONMENT VARIABLES & SECRETS ---
# Crucial: This prevents leaking your API keys and sensitive data
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- LOGS ---
# Error and debug logs generated by package managers
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
bun-debug.log*

# --- EDITOR SETTINGS ---
# Project-specific settings for VS Code or WebStorm
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OPERATING SYSTEM ---
# System-specific files that don't belong in the repo
.DS_Store
.DS_Store?
._*
thumbs.db
desktop.ini

# --- TESTING ---
# Coverage reports from Vitest or Jest
coverage/